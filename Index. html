<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>Sorry Angry Bird</title>

<style>

body{
margin:0;
height:100vh;
display:flex;
justify-content:center;
align-items:center;
background:linear-gradient(135deg,#ff9a9e,#fad0c4);
font-family:Arial;
overflow:hidden;
}

.card{
background:white;
padding:35px;
border-radius:20px;
text-align:center;
width:330px;
box-shadow:0 10px 25px rgba(0,0,0,0.2);
animation: pop 1s ease;
}

@keyframes pop{
0%{transform:scale(0)}
100%{transform:scale(1)}
}

h1{
color:#ff4d6d;
}

button{
padding:12px 24px;
border:none;
border-radius:12px;
margin:10px;
font-size:16px;
cursor:pointer;
transition:0.3s;
}

.love{
background:#ff4d6d;
color:white;
}

.hate{
background:#444;
color:white;
position:relative;
}

button:hover{
transform:scale(1.1);
}

#result{
margin-top:20px;
font-size:20px;
color:#ff4d6d;
}

.heart{
position:absolute;
font-size:22px;
animation: fall 3s linear forwards;
}

@keyframes fall{
0%{transform:translateY(-100px);opacity:1;}
100%{transform:translateY(100vh);opacity:0;}
}

</style>
</head>

<body>

<div class="card">

<h1>Sorry Angry Bird 🐦</h1>

<p>
I know you are angry... 🥺  
I'm really sorry.  
Please forgive me 💌
</p>

<p>Choose honestly 😅</p>

<button class="love" onclick="love()">Love You ❤️</button>
<button class="hate" id="hateBtn">Hate You 😒</button>

<div id="result"></div>

</div>

<script>

function love(){
document.getElementById("result").innerHTML="Yayyy!! ❤️ I love you too!! 💖💖💖";

for(let i=0;i<25;i++){
let heart=document.createElement("div");
heart.classList.add("heart");
heart.innerHTML="❤️";
heart.style.left=Math.random()*100+"vw";
heart.style.animationDuration=(2+Math.random()*3)+"s";
document.body.appendChild(heart);

setTimeout(()=>{heart.remove()},4000);
}
}

const hateBtn=document.getElementById("hateBtn");

hateBtn.addEventListener("mouseover",()=>{
let x=Math.random()*300-150;
let y=Math.random()*200-100;

hateBtn.style.transform=`translate(${x}px,${y}px)`;
});

hateBtn.addEventListener("click",()=>{
document.getElementById("result").innerHTML="🤗 Big Hug!! I still love you moreee ❤️";
});

</script>

</body>
</html>
